<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:paddingHorizontal="20dp"
    tools:context=".ForgotPasswordCode">


    <ImageView
        android:id="@+id/forgotCodeImage"
        android:layout_width="193dp"
        android:layout_height="193dp"
        android:adjustViewBounds="true"
        android:src="@drawable/logomain"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/forgotCodeBack"
        android:layout_width="39dp"
        android:layout_height="39dp"
        android:layout_marginTop="62dp"
        android:adjustViewBounds="true"
        android:background="@drawable/btn_back"
        android:paddingHorizontal="15dp"
        android:src="@drawable/chevron_left"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/forgotCodeTextH1"
        android:layout_width="339dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="170dp"
        android:text="Please check your email"
        android:textSize="30sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/forgotCodeTextH2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="We've sent a code to helloworld@gmail.com"
        app:layout_constraintTop_toBottomOf="@id/forgotCodeTextH1"
        app:layout_constraintStart_toStartOf="@id/forgotCodeTextH1"
        app:layout_constraintEnd_toEndOf="@id/forgotCodeTextH1"
        android:textSize="16sp"
        android:layout_marginTop="10dp"
        />

    <LinearLayout
        android:id="@+id/forgotCodeInt"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/forgotCodeTextH2"
        app:layout_constraintStart_toStartOf="@id/forgotCodeTextH2"
        app:layout_constraintEnd_toEndOf="@id/forgotCodeTextH2"
        android:orientation="horizontal"
        android:layout_marginTop="30dp"
        android:weightSum="4"

        >
        <TextView
            android:layout_width="77dp"
            android:layout_height="77dp"
            android:layout_weight="1"
            android:background="@drawable/verify_code"
            android:layout_marginEnd="10dp"
            android:text="8"
            android:layout_gravity="center"
            android:textAlignment="center"
            android:textSize="32sp"
            android:paddingTop="15dp"

            />
        <TextView
            android:layout_weight="1"
            android:layout_width="77dp"
            android:layout_height="77dp"
            android:layout_marginHorizontal="10dp"
            android:background="@drawable/verify_code"
            android:text="2"
            android:layout_gravity="center"
            android:textAlignment="center"
            android:textSize="32sp"
            android:paddingTop="15dp"
            />
        <TextView
            android:layout_weight="1"
            android:layout_width="77dp"
            android:layout_height="77dp"
            android:layout_marginHorizontal="10dp"
            android:text="2"
            android:layout_gravity="center"
            android:textAlignment="center"
            android:textSize="32sp"
            android:paddingTop="15dp"
            android:background="@drawable/verify_code"
            />
        <TextView
            android:layout_weight="1"
            android:layout_width="77dp"
            android:layout_height="77dp"
            android:layout_marginStart="10dp"
            android:background="@drawable/verify_code"
            />

    </LinearLayout>

    <TextView
        android:id="@+id/forgotCodeVerify"
        app:layout_constraintStart_toStartOf="@id/forgotCodeInt"
        app:layout_constraintTop_toBottomOf="@id/forgotCodeInt"
        app:layout_constraintEnd_toEndOf="@id/forgotCodeInt"
        android:background="@drawable/btnsignin"
        android:text="Verify"
        android:textAlignment="center"
        android:paddingVertical="20dp"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:textFontWeight="400"
        android:layout_marginTop="40dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

    <LinearLayout
        android:id="@+id/forgotCodeTextEnd"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="@id/forgotCodeVerify"
        app:layout_constraintStart_toStartOf="@id/forgotCodeVerify"
        android:gravity="center"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/forgotCodeVerify">

        <TextView
            android:id="@+id/forgotCodeTextAgain"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textStyle="bold"
            android:text="Send code again"
            />

        <TextView
            android:id="@+id/forgotCodeTextTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="4dp"
            android:textColor="@color/black"
            android:text="00:20"
            />

    </LinearLayout>


</androidx.constraintlayout.widget.ConstraintLayout>